{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MiControl",
  "version": "1.0.0",
  "identifier": "com.micontrol.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MiControl",
        "width": 950,
        "height": 660,
        "minWidth": 600,
        "minHeight": 560,
        "resizable": true,
        "decorations": true,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self'; font-src 'self'; connect-src 'self' https:; object-src 'none'; base-uri 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../drivers/VirtualControlHID/*": "drivers/VirtualControlHID/",
      "../../drivers/IoTDriver/*": "drivers/IoTDriver/"
    },
    "windows": {
      "nsis": {
        "installerHooks": "./nsis/installer-hooks.nsi"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZCQjc3MTVCMkVDNDEyRDQKUldUVUVzUXVXM0czKzl2bGpUdjFrc2Nsd0d3SUwwUmJ3WGIrVTRELyt6VFZ0UEpsTWpqV3lKbHMK",
      "endpoints": ["https://github.com/Freitas-MA/micontrol/releases/latest/download/latest.json"]
    }
  }
}
