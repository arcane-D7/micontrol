# miPC Environment Variables
#
# Copy this file to `.env` and fill in the values.
# The `.env` file is NOT committed to git.

# ─── Sentry (Crash Reporting) ───────────────────────────────────────────────
# Sentry DSN for crash reporting. Only active if the user grants telemetry consent.
# Get your DSN from: https://sentry.io/settings/<org>/projects/<project>/keys/
# Optional — if not set, crash reporting is disabled.
VITE_SENTRY_DSN=

# ─── Code Signing (CI Only) ─────────────────────────────────────────────────
# Password for the Authenticode code signing certificate.
# Used only in the GitHub Actions release workflow.
# Do NOT set this in your local .env file.
# WINDOWS_CERTIFICATE_PASSWORD=
