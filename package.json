{
  "name": "micontrol",
  "version": "0.1.11",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mock": "vite --config vite.config.mock.ts",
    "dev:landing": "vite --config vite.config.landing.ts",
    "build": "tsc && vite build",
    "build:landing": "vite build --config vite.config.landing.ts",
    "preview:landing": "vite preview --config vite.config.landing.ts",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "tauri": "tauri",
    "clean": "node scripts/clean-build-artifacts.mjs",
    "clean:rust": "cd src-tauri && cargo clean",
    "lint": "eslint src",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "version:sync": "node scripts/sync-version.cjs",
    "version:check": "node scripts/sync-version.cjs --check",
    "version:bump": "node scripts/sync-version.cjs",
    "release": "node scripts/release.cjs",
    "commitlint": "commitlint --from=HEAD~1 --to=HEAD",
    "commitlint:check": "commitlint --edit",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@sentry/react": "^8.0.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "gsap": "^3.15.0",
    "lenis": "^1.3.25",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.49.0",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.1.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^4.5.0",
    "@vitest/coverage-v8": "^3.2.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.0",
    "jsdom": "^26.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.9.5",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^6.3.5",
    "vitest": "^3.2.2"
  }
}
